# Google Places API (required for Scout agent)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# SMTP Email (required for Pitcher agent to send emails)
# For Gmail: use smtp.gmail.com with an App Password
# Create App Password: Google Account → Security → 2-Step Verification → App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
